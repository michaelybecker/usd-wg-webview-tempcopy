#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 0.01
)

def Xform "World"
{
    def Xform "RedBox" (
        payload = @./red_box.usda@
    )
    {
        double3 xformOp:translate = (-160, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "BlueBox" (
        payload = @./blue_box.usda@
    )
    {
        double3 xformOp:translate = (160, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
