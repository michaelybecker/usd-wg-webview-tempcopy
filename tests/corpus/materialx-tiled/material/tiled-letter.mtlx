<?xml version="1.0"?>
<materialx version="1.38" colorspace="lin_rec709">
  <nodegraph name="NG_tiledLetter">
    <image name="letterImage" type="color3">
      <input name="file" type="filename" value="letter-f.png" colorspace="srgb_texture" />
      <input name="uaddressmode" type="string" value="periodic" />
      <input name="vaddressmode" type="string" value="periodic" />
    </image>
    <output name="baseColorOut" type="color3" nodename="letterImage" />
  </nodegraph>
  <standard_surface name="SR_tiledLetter" type="surfaceshader">
    <input name="base" type="float" value="1.0" />
    <input name="base_color" type="color3" nodegraph="NG_tiledLetter" output="baseColorOut" />
    <input name="specular_roughness" type="float" value="0.5" />
  </standard_surface>
  <surfacematerial name="M_tiledLetter" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="SR_tiledLetter" />
  </surfacematerial>
</materialx>
